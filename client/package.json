{
  "name": "@game-workspace/client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "concurrently --kill-others \"npm run dev\" \"cd .. && cd server && npm run dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --report-unused-disable-directives --max-warnings 0 --fix",
    "style": "stylelint \"**/*.scss\"",
    "style:fix": "stylelint \"**/*.scss\" --fix",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,scss,css,md,mjs}\"",
    "test": "jest --config ./config/jest/jest.config.ts"
  },
  "dependencies": {
    "@game-workspace/checkers": "*",
    "@game-workspace/shared": "*",
    "axios": "^1.12.1",
    "classnames": "^2.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "styled-components": "^6.1.13",
    "zustand": "^5.0.0-rc.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "sass": "^1.80.6",
    "typescript": "5.5.3",
    "vite": "^5.4.1",
    "vite-plugin-svgr": "^4.2.0"
  }
}
